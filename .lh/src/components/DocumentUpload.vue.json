unks = [];\r\n+  for (let i = 0; i < cleanText.length; i += chunkSize) {\r\n+    // 避免分割到单词中间，提升文本块完整性\r\n+    let end = i + chunkSize;\r\n+    if (end < cleanText.length) {\r\n+      const spaceIndex = cleanText.lastIndexOf(' ', end);\r\n+      if (spaceIndex > i) {\r\n+        end = spaceIndex;\r\n+      }\r\n+    }\r\n+    textChunks.push(cleanText.slice(i, end).trim());\r\n+  }\r\n+  return textChunks;\r\n+}\r\n+\r\n+// 解析文件（Day2完善，核心逻辑）\r\n+const handleParseFile = () => {\r\n+  if (!file.value) {\r\n+    alert('请先上传文档！')\r\n+    return\r\n+  }\r\n+\r\n+  // 使用FileReader读取文件内容\r\n+  const reader = new FileReader()\r\n+  // 读取文本格式（TXT、MD均按纯文本处理）\r\n+  reader.readAsText(file.value, 'utf-8')\r\n+\r\n+  // 读取成功后的回调\r\n+  reader.onload = (e) => {\r\n+    const rawText = e.target.result // 读取到的原始文本\r\n+    // 调用清洗分割函数，获取处理后的文本块\r\n+    const chunks = cleanAndSplitText(rawText)\r\n+    textChunks.value = chunks\r\n+\r\n+    // 同步到Pinia仓库（Day2核心：状态同步）\r\n+    ragStore.addDocument({\r\n+      fileName: fileName.value,\r\n+      textChunks: chunks,\r\n+      uploadTime: new Date().toLocaleString()\r\n+    })\r\n+\r\n+    alert('文档解析成功！已将文本块存储到仓库')\r\n+  }\r\n+\r\n+  // 读取失败的回调（Day2新增：错误处理）\r\n+  reader.onerror = () => {\r\n+    alert('文档解析失败，请重新上传有效的TXT/MD文件')\r\n+  }\r\n+}\r\n+</script>\n\\ No newline at end of file\n"
