                    "content": "Index: \n===================================================================\n--- \n+++ \n@@ -0,0 +1,100 @@\n+<template>\r\n+  <div class=\"upload-container\">\r\n+    <h3>文档上传（支持TXT、MD格式）</h3>\r\n+    <input type=\"file\" class=\"input\" accept=\".txt,.md\" @change=\"handleFileUpload\" />\r\n+    <button class=\"btn\" @click=\"handleParseFile\">解析文档</button&gt; <!-- 显示已上传文档名称 -->\r\n+      <div v-if=\"fileName\" class=\"file-info\">\r\n+        已上传：{{ fileName }}\r\n+        &lt;/div&gt;\r\n+\r\n+        <!-- 显示解析后的文本块（Day2新增） -->\r\n+        <div v-if=\"textChunks.length\" class=\"text-chunks\" style=\"margin-top: 20px;\">\r\n+          <h4 style=\"margin-bottom: 10px;\">解析后的文本块（共{{ textChunks.length }}块）</h4>\r\n+          <div class=\"chunk-item\"\r\n+            style=\"border: 1px solid #eee; padding: 10px; margin-bottom: 10px; border-radius: 4px;\"\r\n+            v-for=\"(chunk, index) in textChunks\" :key=\"index\">\r\n+            {{ index + 1 }}. {{ chunk }}\r\n+          </div>\r\n+        </div>\r\n+      </div>\r\n+</template>\r\n+\r\n+<script setup>\r\n+import { ref } from 'vue'\r\n+import { useRagStore } from '../store/ragStore'\r\n+\r\n+const ragStore = useRagStore()\r\n+const file = ref(null) // 存储上传的文件\r\n+const fileName = ref('') // 存储文件名\r\n+const textChunks = ref([]) // 存储解析、清洗后的文本块（Day2新增）\r\n+\r\n+// 处理文件上传（Day1原有，无修改）\r\n+const handleFileUpload = (e) => {\r\n+  const selectedFile = e.target.files[0]\r\n+  if (selectedFile) {\r\n+    file.value = selectedFile\r\n+    fileName.value = selectedFile.name\r\n+    textChunks.value = [] // 重置文本块，避免重复解析\r\n+  }\r\n+}\r\n+\r\n+// 文本清洗 + 长文本分割函数（Day2新增，核心）\r\n+const cleanAndSplitText = (text) => {\r\n+  // 1. 清洗文本：去除多余空格、换行、制表符，统一换行格式\r\n+  let cleanText = text\r\n+    .replace(/\\s+/g, ' ') // 多个空格替换为单个空格\r\n+    .replace(/\\n+/g, '\\n') // 多个换行替换为单个换行\r\n+    .trim(); // 去除首尾空格\r\n+\r\n+  // 2. 分割长文本为段落块（每200字左右一块，便于后续向量生成）\r\n+  const chunkSize = 200;\r\n+  const textChunks = [];\r\n+  for (let i = 0; i < cleanText.length; i += chunkSize) {\r\n+    // 避免分割到单词中间，提升文本块完整性\r\n+    let end = i + chunkSize;\r\n+    if (end < cleanText.length) {\r\n+      const spaceIndex = cleanText.lastIndexOf(' ', end);\r\n+      if (spaceIndex > i) {\r\n+        end = spaceIndex;\r\n+      }\r\n+    }\r\n+    textChunks.push(cleanText.slice(i, end).trim());\r\n+  }\r\n+  return textChunks;\r\n+}\r\n+\r\n+// 解析文件（Day2完善，核心逻辑）\r\n+const handleParseFile = () => {\r\n+  if (!file.value) {\r\n+    alert('请先上传文档！')\r\n+    return\r\n+  }\r\n+\r\n+  // 使用FileReader读取文件内容\r\n+  const reader = new FileReader()\r\n+  // 读取文本格式（TXT、MD均按纯文本处理）\r\n+  reader.readAsText(file.value, 'utf-8')\r\n+\r\n+  // 读取成功后的回调\r\n+  reader.onload = (e) => {\r\n+    const rawText = e.target.result // 读取到的原始文本\r\n+    // 调用清洗分割函数，获取处理后的文本块\r\n+    const chunks = cleanAndSplitText(rawText)\r\n+    textChunks.value = chunks\r\n+\r\n+    // 同步到Pinia仓库（Day2核心：状态同步）\r\n+    ragStore.addDocument({\r\n+      fileName: fileName.value,\r\n+      textChunks: chunks,\r\n+      uploadTime: new Date().toLocaleString()\r\n+    })\r\n+\r\n+    alert('文档解析成功！已将文本块存储到仓库')\r\n+  }\r\n+\r\n+  // 读取失败的回调（Day2新增：错误处理）\r\n+  reader.onerror = () => {\r\n+    alert('文档解析失败，请重新上传有效的TXT/MD文件')\r\n+  }\r\n+}\r\n+</script>\n\\ No newline at end of file\n"
                },
